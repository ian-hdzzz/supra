# ─────────────────────────────────────────────
# Base de datos
# ─────────────────────────────────────────────

# Local (PostgreSQL vía Homebrew):
# DATABASE_URL="postgresql://tu_usuario:tu_password@localhost:5432/supra_db"
#
# EasyPanel (prod) — toma la variable de entorno de tu servicio de Postgres:
# DATABASE_URL="postgresql://usuario:password@host:5432/supra_db"

DATABASE_URL="postgresql://supra:supra_pass@localhost:5432/supra_db"

# ─────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────

PORT=3001
SERVER_BASE_URL=http://localhost:3001

# ─────────────────────────────────────────────
# JWT — cambia en producción
# ─────────────────────────────────────────────

JWT_SECRET=cambia_esto_en_produccion

# ─────────────────────────────────────────────
# APIs externas (opcionales)
# ─────────────────────────────────────────────

GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# CORS — orígenes permitidos (separados por coma)
# ─────────────────────────────────────────────

ALLOWED_ORIGINS=http://localhost:5173,https://supra.whoopflow.com
